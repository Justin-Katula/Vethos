{
  "name": "vethos",
  "version": "0.12.0",
  "private": true,
  "description": "Vethos — application desktop de focus",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && npm run build:service && electron-builder --win --dir && node scripts/build-simple-installer.mjs",
    "build:unpack": "electron-vite build && npm run build:service && electron-builder --win --dir",
    "build:portable": "electron-vite build && npm run build:service && electron-builder --win portable",
    "build:service": "vite build --config electron.vite.service.config.ts",
    "dev:service": "node scripts/run-service-dev.mjs",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.5.0",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.1"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "clsx": "^2.1.1",
    "culori": "^4.0.2",
    "date-fns": "^4.1.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "framer-motion": "^11.18.2",
    "lodash-es": "^4.18.1",
    "lucide-react": "^0.378.0",
    "node-windows": "^1.0.0-beta.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "sudo-prompt": "^9.2.1",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  }
}
